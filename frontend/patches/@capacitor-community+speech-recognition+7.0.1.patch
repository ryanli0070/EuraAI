+import PackageDescription
+
+let package = Package(
+    name: "CapacitorCommunitySpeechRecognition",
+    platforms: [.iOS(.v15)],
+    products: [
+        .library(
+            name: "CapacitorCommunitySpeechRecognition",
+            targets: ["SpeechRecognitionPlugin"])
+    ],
+    dependencies: [
