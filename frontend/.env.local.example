# Copy to .env.local and fill in. Unset VITE_API_BASE_URL => http://localhost:8000.
VITE_API_BASE_URL=http://localhost:8000

# From the Supabase dashboard: Project Settings -> API.
# Use the publishable key (sb_publishable_...), not the legacy anon JWT.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
