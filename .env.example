# Copy this file to .env and fill in your keys. Never commit .env.

OPENAI_API_KEY=sk-...

# Comma-separated list of allowed frontend origins for CORS.
# Default if unset: http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Pix2Text — optional override for local model cache. Defaults to ~/.pix2text.
# In production set this to a persistent volume so models aren't redownloaded.
P2T_MODEL_DIR=

# (If switching from Pix2Text to Mathpix later — see app/services/ocr.py)
# MATHPIX_APP_ID=
# MATHPIX_APP_KEY=
